# .env.example
# ==========================
# Flask / App
# ==========================
FLASK_DEBUG=1
HOST=127.0.0.1
PORT=5000

# Chave da aplicação (OBRIGATÓRIA em produção).
# Em DEV você pode deixar sem no .env; o app usa fallback "dev-secret".
SECRET_KEY=defina-uma-chave-secreta

# ==========================
# Banco de Dados (escolha UMA linha e deixe as demais comentadas)
# ==========================

# SQLite (caminho ABSOLUTO - macOS/Linux)  → 4 barras após sqlite:
# DATABASE_URL=sqlite:////Users/SEU_USUARIO/Desktop/Cadastro_Sementes_do_Amanha/Cadastro_Sementes_do_Amanha/sementes.db

# SQLite (caminho RELATIVO na raiz do projeto)
# DATABASE_URL=sqlite:///sementes.db

# SQLite (caminho ABSOLUTO - Windows)  → 3 barras + drive:
# DATABASE_URL=sqlite:///C:/Users/SEU_USUARIO/Desktop/Cadastro_Sementes_do_Amanha/Cadastro_Sementes_do_Amanha/sementes.db

# Postgres (exemplo futuro)
# DATABASE_URL=postgresql+psycopg2://usuario:senha@localhost:5432/sementes

# MySQL/MariaDB (exemplo futuro)
# DATABASE_URL=mysql+pymysql://usuario:senha@localhost:3306/sementes

# ==========================
# CORS (opcional, se houver frontend separado)
# ==========================
# CORS_ORIGINS=*            # ou liste origens separadas por vírgula, ex: http://localhost:3000,http://127.0.0.1:3000